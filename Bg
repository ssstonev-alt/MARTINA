  </div>

  <!-- ══════════════════════════════════════════════
       РАЗДЕЛ 4 – ТЕСТ
  ═══════════════════════════════════════════════ -->
  <div id="quiz" class="section">
    <h2 class="section-title">Тест за самопроверка</h2>
    <p class="section-desc">20 въпроса от цялата програма · Получаваш обратна връзка след всеки отговор.</p>
    <div class="quiz-wrap">
      <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="qProgress" style="width:0%"></div></div>
      <div id="quizMain">
        <div class="quiz-q-num" id="qNum"></div>
        <div class="quiz-question" id="qText"></div>
        <div class="quiz-options" id="qOpts"></div>
        <div class="quiz-feedback" id="qFeedback"></div>
        <button class="quiz-next-btn" id="qNext" onclick="nextQ()">Следващ въпрос →</button>
      </div>
      <div class="quiz-score-wrap" id="quizScore">
        <div class="quiz-score-big" id="scoreBig"></div>
        <div class="quiz-score-label" id="scoreLabel"></div>
        <button class="quiz-restart-btn" onclick="restartQuiz()">Опитай отново</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       РАЗДЕЛ 5 – ФЛАШКАРТИ
  ═══════════════════════════════════════════════ -->
  <div id="flash" class="section">
    <h2 class="section-title">Флашкарти</h2>
    <p class="section-desc">Кликни върху картата, за да видиш определението. Навигирай с бутоните.</p>
    <div class="flashcard-wrap">
      <div class="flashcard" id="flashcard" onclick="flipCard()">
        <div class="fc-face fc-front">
          <div class="fc-hint">Термин</div>
          <div class="fc-term" id="fcTerm"></div>
        </div>
        <div class="fc-face fc-back">
          <div class="fc-hint">Определение</div>
          <div class="fc-def" id="fcDef"></div>
        </div>
      </div>
      <div class="fc-controls">
        <button class="fc-btn" onclick="prevCard()">← Назад</button>
        <span class="fc-counter" id="fcCounter"></span>
        <button class="fc-btn" onclick="nextCard()">Напред →</button>
      </div>
    </div>
  </div>

</main>

<script>
// ── NAV ──
function showSection(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  event.target.classList.add('active');
}

// ── TOPIC CARDS ──
function toggleCard(el) {
  const wasOpen = el.classList.contains('open');
  // close siblings in same grid
  el.closest('.topic-grid') && el.closest('.topic-grid').querySelectorAll('.topic-card').forEach(c => c.classList.remove('open'));
  if (!wasOpen) el.classList.add('open');
}

// ── QUIZ DATA ──
const quizData = [
  { q:'Кой е авторът на „Илиада"?', opts:['Омир','Сафо','Хезиод','Вергилий'], a:0 },
  { q:'Какъв жанр е „Антигона" на Софокъл?', opts:['Комедия','Трагедия','Епос','Новела'], a:1 },
  { q:'Какво е „катарзис"?', opts:['Вид сравнение','Очистване от страх и съжаление','Трагически герой','Акростих'], a:1 },
  { q:'Кой е автор на „За буквите"?', opts:['Климент Охридски','Константин Преславски','Черноризец Храбър','Кирил'], a:2 },
  { q:'Акростих е поетична форма, при която...', opts:['думите се римуват','началните букви на редовете образуват дума','стиховете са 14','няма рима'], a:1 },
  { q:'„Притчата за трите пръстена" е от кой сборник?', opts:['Хамлет','Декамерон','Дон Кихот','Илиада'], a:1 },
  { q:'Какво изразява страдателният залог?', opts:['Подлогът извършва действието','Подлогът е обект на действието','Действието е завършено','Действието е продължително'], a:1 },
  { q:'„Прочетох книгата" – глаголът е в...', opts:['несвършен вид','страдателен залог','свършен вид','сегашно време'], a:2 },
  { q:'Кой стил използва термини и безличен изказ?', opts:['Разговорен','Художествен','Научен','Публицистичен'], a:2 },
  { q:'Сонетът се състои от колко стиха?', opts:['10','12','14','16'], a:2 },
  { q:'„Хамлет" е произведение на...', opts:['Сервантес','Бокачо','Шекспир','Данте'], a:2 },
  { q:'Какъв жанр е „Пространно житие на Константин–Кирил"?', opts:['Новела','Трагедия','Агиография / Житие','Роман'], a:2 },
  { q:'Постоянният епитет е характерен за...', opts:['Сонетите на Шекспир','„Илиада" на Омир','„Антигона" на Софокъл','„За буквите"'], a:1 },
  { q:'Фразеологизмът се различава от свободното словосъчетание по това, че...', opts:['е по-кратко','думите му са с преносно значение като цяло','е неологизъм','е заемка'], a:1 },
  { q:'„Дон Кихот" принадлежи към епохата на...', opts:['Античността','Средновековието','Ренесанса','Просвещението'], a:2 },
  { q:'Каква е основната тема на Сонет 130 на Шекспир?', opts:['Смъртта','Реалистично описание на любимата, без идеализация','Войната','Религията'], a:1 },
  { q:'Кодификацията на езика означава...', opts:['Превод на текст','Записване на нормата в речници и наръчници','Създаване на диалект','Стилно разнообразие'], a:1 },
  { q:'Подчиненото допълнително изречение отговаря на въпроса...', opts:['Кога?','Какво? / Кого?','Какъв?','Защо?'], a:1 },
  { q:'Религиозната търпимост е централна тема в...', opts:['„Илиада"','„Антигона"','„Притчата за трите пръстена"','„Хамлет"'], a:2 },
  { q:'„Азбучна молитва" е написана от...', opts:['Климент Охридски','Черноризец Храбър','Константин Преславски','Йоан Екзарх'], a:2 },
];

let qIdx = 0, score = 0, answered = false;

function renderQ() {
  const q = quizData[qIdx];
  document.getElementById('qNum').textContent = `Въпрос ${qIdx+1} от ${quizData.length}`;
  document.getElementById('qText').textContent = q.q;
  document.getElementById('qProgress').style.width = ((qIdx/quizData.length)*100)+'%';
  const opts = document.getElementById('qOpts');
  opts.innerHTML = '';
  q.opts.forEach((o,i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-opt';
    btn.textContent = o;
    btn.onclick = () => checkAnswer(i, btn);
    opts.appendChild(btn);
  });
  const fb = document.getElementById('qFeedback');
  fb.className = 'quiz-feedback';
  fb.textContent = '';
  document.getElementById('qNext').className = 'quiz-next-btn';
  answered = false;
}

function checkAnswer(idx, btn) {
  if (answered) return;
  answered = true;
  const q = quizData[qIdx];
  const allBtns = document.querySelectorAll('.quiz-opt');
  allBtns.forEach(b => b.disabled = true);
  const fb = document.getElementById('qFeedback');
  if (idx === q.a) {
    btn.classList.add('correct');
    fb.textContent = '✓ Правилно!';
    fb.className = 'quiz-feedback show ok';
    score++;
  } else {
    btn.classList.add('wrong');
    allBtns[q.a].classList.add('correct');
    fb.textContent = `✗ Грешно. Правилният отговор е: „${q.opts[q.a]}"`;
    fb.className = 'quiz-feedback show fail';
  }
  document.getElementById('qNext').className = 'quiz-next-btn show';
}

function nextQ() {
  qIdx++;
  if (qIdx >= quizData.length) {
    document.getElementById('quizMain').style.display = 'none';
    const sw = document.getElementById('quizScore');
    sw.className = 'quiz-score-wrap show';
    document.getElementById('scoreBig').textContent = `${score}/${quizData.length}`;
    const pct = Math.round(score/quizData.length*100);
    document.getElementById('scoreLabel').textContent =
      pct >= 90 ? '🏆 Отличен резултат!' :
      pct >= 70 ? '👍 Добре! Можеш и по-добре.' :
      '📖 Прегледай материала отново.';
    document.getElementById('qProgress').style.width = '100%';
  } else {
    renderQ();
  }
}

function restartQuiz() {
  qIdx = 0; score = 0;
  document.getElementById('quizMain').style.display = '';
  document.getElementById('quizScore').className = 'quiz-score-wrap';
  renderQ();
}

// ── FLASHCARDS ──
const flashCards = [
  {t:'Катарзис', d:'Очистване на зрителя от страх и съжаление след гледане на трагедия (Аристотел).'},
  {t:'Постоянен епитет', d:'Устойчив образен израз, свързан с определен герой в епоса: „бързоногият Ахил", „розовопръстата Зора".'},
  {t:'Акростих', d:'Поетична форма, при която началните букви на редовете образуват дума или азбука. Пример: „Азбучна молитва".'},
  {t:'Агиография', d:'Жанр – биографии на светци; включва описание на живота, чудесата и добродетелите им.'},
  {t:'Полемично слово', d:'Текст, насочен срещу противник с контра-аргументи; вид апология. Пример: „За буквите".'},
  {t:'Пародия', d:'Комично подражание на жанр или стил с цел осмиване. В „Дон Кихот" – пародия на рицарски романи.'},
  {t:'Сонет', d:'14 стиха в 3 катрена + 1 куплет; рима abab cdcd efef gg. Изразява един основен образ или идея.'},
  {t:'Страдателен залог', d:'Глаголна форма, при която подлогът е обект на действието: „Писмото беше написано." Образува се с „съм/бъда + мин. страд. причастие" или „се".'},
  {t:'Свършен вид', d:'Действието е завършено, ограничено: „напиша", „дойда". Противопоставя се на несвършен вид.'},
  {t:'Фразеологизъм', d:'Устойчиво словосъчетание с преносно значение, различно от буквалното: „хвърлям камък в чуждата градина" = вреди на някого.'},
  {t:'Трагически герой', d:'Благороден герой с фатален недостатък (хибрис), унищожен от конфликт с неизбежна сила или съдба.'},
  {t:'Новела', d:'Кратък прозаичен жанр с неочакван обрат; действието е концентрирано около едно събитие.'},
  {t:'Кодификация', d:'Записване и фиксиране на езиковата норма в речници, граматики и правописни наръчници.'},
  {t:'Епическо сравнение', d:'Разгърнато сравнение в епоса, което образува самостоятелна картина и забавя действието.'},
  {t:'Символ', d:'Знак или образ с допълнително, по-дълбоко значение. В „Житие на Константин–Кирил" орелът символизира величие.'},
];

let fcIdx = 0;

function renderCard() {
  const c = flashCards[fcIdx];
  document.getElementById('fcTerm').textContent = c.t;
  document.getElementById('fcDef').textContent = c.d;
  document.getElementById('fcCounter').textContent = `${fcIdx+1} / ${flashCards.length}`;
  document.getElementById('flashcard').classList.remove('flipped');
}

function flipCard() { document.getElementById('flashcard').classList.toggle('flipped'); }
function nextCard() { fcIdx = (fcIdx+1) % flashCards.length; renderCard(); }
function prevCard() { fcIdx = (fcIdx - 1 + flashCards.length) % flashCards.length; renderCard(); }

// ── INIT ──
renderQ();
renderCard();
</script>
</body>
</html>
